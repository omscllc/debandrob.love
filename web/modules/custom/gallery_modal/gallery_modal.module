<?php

/**
 * @file
 * Gallery Modal module hooks.
 */

use Drupal\Component\Utility\Html;

/**
 * Implements hook_theme().
 */
function gallery_modal_theme($existing, $type, $theme, $path) {
  return [
    'gallery_modal' => [
      'variables' => [
        'image_url' => NULL,
        'alt' => '',
        'media_name' => '',
        'comments' => [],
        'comment_form' => [],
        'can_share' => FALSE,
        'share_url' => '',
        'share_image_url' => '',
        'prev_id' => NULL,
        'next_id' => NULL,
        'current_id' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_views_view_masonry().
 *
 * Add data-media-id attribute and gallery-modal library to gallery masonry items.
 */
function gallery_modal_preprocess_views_view_masonry(&$variables) {
  $view = $variables['view'];
  if ($view->storage->id() !== 'gallery') {
    return;
  }

  $media_ids = [];
  foreach ($variables['rows'] as $id => $row) {
    $entity = $view->result[$id]->_entity ?? NULL;
    if ($entity) {
      $media_ids[] = (int) $entity->id();
    }
  }

  $commented_media = [];
  if (!empty($media_ids)) {
    $commented_ids = \Drupal::database()
      ->select('comment_field_data', 'cfd')
      ->fields('cfd', ['entity_id'])
      ->condition('entity_type', 'media')
      ->condition('field_name', 'field_album_comments')
      ->condition('status', 1)
      ->condition('entity_id', $media_ids, 'IN')
      ->distinct()
      ->execute()
      ->fetchCol();

    if (!empty($commented_ids)) {
      $commented_media = array_flip(array_map('intval', $commented_ids));
    }
  }

  foreach ($variables['rows'] as $id => &$row) {
    $entity = $view->result[$id]->_entity ?? NULL;
    if ($entity) {
      $media_id = (int) $entity->id();
      $row['attributes']->setAttribute('data-media-id', Html::escape((string) $media_id));
      $row['attributes']->addClass('gallery-modal-trigger');
      if (isset($commented_media[$media_id])) {
        $row['attributes']->addClass('gallery-modal-trigger--has-comments');
        $row['attributes']->setAttribute('title', (string) \Drupal::translation()->translate('Has comments'));
      }
    }
  }

  $variables['#attached']['library'][] = 'gallery_modal/gallery-modal';

  // Inject a sizer element for responsive column widths.
  $variables['masonry_sizer'] = TRUE;
}
