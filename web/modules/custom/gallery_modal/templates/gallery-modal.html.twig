{#
/**
 * @file
 * Template for gallery modal dialog content.
 *
 * Variables:
 * - image_url: URL to the full-size image.
 * - alt: Alt text for the image.
 * - media_name: The media entity name.
 * - comments: Rendered comments array.
 * - comment_form: Rendered comment form.
 * - can_share: Whether the user can share to social media.
 * - share_url: URL to share.
 * - share_image_url: Image URL for share services.
 * - prev_id: Previous media ID (newer).
 * - next_id: Next media ID (older).
 * - current_id: Current media ID.
 */
#}
<div class="gallery-modal" data-current-media-id="{{ current_id }}">
  <div class="gallery-modal__image">
    {% if prev_id %}
      <button type="button" class="gallery-modal__nav gallery-modal__nav--prev" data-media-id="{{ prev_id }}" aria-label="{{ 'Previous photo'|t }}">
        <span class="gallery-modal__nav-icon">‹</span>
      </button>
    {% endif %}
    
    <img src="{{ image_url }}" alt="{{ alt }}" loading="eager">
    
    {% if next_id %}
      <button type="button" class="gallery-modal__nav gallery-modal__nav--next" data-media-id="{{ next_id }}" aria-label="{{ 'Next photo'|t }}">
        <span class="gallery-modal__nav-icon">›</span>
      </button>
    {% endif %}
  </div>

  <div class="gallery-modal__sidebar">
    <div class="gallery-modal__comments" id="gallery-modal-comments">
      <h3 class="gallery-modal__comments-title">{{ 'Comments'|t }}</h3>
      {% if comments %}
        {{ comments }}
      {% else %}
        <p class="gallery-modal__no-comments">{{ 'No comments yet. Be the first to comment!'|t }}</p>
      {% endif %}
    </div>

    {% if comment_form %}
      <div class="gallery-modal__comment-form">
        {{ comment_form }}
      </div>
    {% endif %}

    {% if can_share %}
      <div class="gallery-modal__share">
        <h4 class="gallery-modal__share-title">{{ 'Share this photo'|t }}</h4>
        <div class="gallery-modal__share-links">
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url|url_encode }}"
             class="gallery-modal__share-link gallery-modal__share-link--facebook"
             target="_blank"
             rel="noopener noreferrer"
             aria-label="{{ 'Share on Facebook'|t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="16" height="16" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <button type="button"
             class="gallery-modal__share-link gallery-modal__share-link--copy"
             data-share-url="{{ share_url }}"
             aria-label="{{ 'Copy link'|t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="9" width="12" height="12" rx="2" ry="2" fill="none"/>
              <rect x="9" y="3" width="12" height="12" rx="2" ry="2" fill="#fff"/>
            </svg>
          </button>
          <span class="gallery-modal__share-toast" role="status" aria-live="polite" aria-atomic="true"></span>
        </div>
      </div>
    {% endif %}
  </div>
</div>
